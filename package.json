    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-alpha.30",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.0.0-alpha.30",
    "tsx": "^4.23.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  }
